{
    "manifest_version": 3,
    "name": "View All Branches",
    "description": "Automatically redirects branch links to show all branches",
    "version": "1.0",
    "permissions": [ "tabs", "scripting", "storage" ],
    "host_permissions": [
        "https://github.com/*/*",
        "https://dev.azure.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "icons": {
        "16": "icon/icon16.png",
        "32": "icon/icon32.png",
        "48": "icon/icon48.png",
        "128": "icon/icon128.png"
    }
}
