{
	"manifest_version": 3,
	"name": "GitHub Branches URL Changer",
	"version": "1.0",
	"permissions": [ "tabs", "scripting", "storage" ],
	"host_permissions": [
		"https://github.com/*/*",
		"https://dev.azure.com/*"
	],
	"action": {
		"default_popup": "popup/popup.html"
	},
	"background": {
		"service_worker": "background/background.js",
		"type": "module"
	}
}
